generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum Platform {
  VK
  TELEGRAM
  INSTAGRAM
}

enum AccountType {
  GROUP     // VK community / группа
  PERSONAL  // VK personal page / личная стена
  CHANNEL   // Telegram channel
  BOT       // Telegram bot (future)
  BUSINESS  // Instagram business (future)
}

enum PostType {
  TEXT
  PHOTO
  VIDEO
  REELS
  CLIPS
  STORIES
}

enum PostStatus {
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum ContentPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum PublishStatus {
  SUCCESS
  FAILED
  RATE_LIMITED
}

// ============================================================
// MODELS
// ============================================================

/// Оператор системы (логин/пароль, JWT auth)
model User {
  id             String   @id @default(cuid())
  login          String   @unique
  passwordHash   String   @map("password_hash")
  name           String
  role           UserRole @default(EDITOR)
  isActive       Boolean  @default(true) @map("is_active")
  sectionAccess  Json?    @map("section_access")
  balanceKopecks Int      @default(0) @map("balance_kopecks") // баланс в копейках (рубли * 100)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  businesses          UserBusiness[]
  ideas               Idea[]
  sessions            GenerationSession[]
  aiUsageLogs         AiUsageLog[]
  balanceTransactions BalanceTransaction[]
  apiKeys             ApiKey[]

  @@map("users")
}

/// API-ключ для внешних интеграций (MCP, webhooks)
model ApiKey {
  id        String    @id @default(cuid())
  keyHash   String    @unique @map("key_hash") // sha256 hash
  name      String                              // "MCP Server", "ERP Integration"
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive  Boolean   @default(true) @map("is_active")
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

/// Привязка пользователя к бизнесу (RBAC)
model UserBusiness {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  businessId String   @map("business_id")
  role       UserRole @default(EDITOR)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("user_businesses")
}

/// Бренд/проект (KB, НаWоде, Inpulse, Личный)
model Business {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // ERP-интеграция (для in-house)
  erpType    String? @map("erp_type") // "nawode" | "kukin" | "inpulse" | null
  erpBaseUrl String? @map("erp_base_url")
  erpApiKey  String? @map("erp_api_key")

  // Яндекс.Метрика per-business (масштабируемо: каждый проект — свой счётчик/цели/токен).
  // Токен (секрет) — НЕ здесь, а в AppConfig `metrika_token_{businessId}` (admin-only, не утекает во фронт).
  metrikaCounterId String?  @map("metrika_counter_id")              // id счётчика (не секрет)
  metrikaGoalIds   String[] @default([]) @map("metrika_goal_ids")    // цели-конверсии (booking-intent и т.п.)

  brandProfile     BrandProfile?
  platformAccounts PlatformAccount[]
  contentPlans     ContentPlan[]
  posts            Post[]
  mediaFolders     MediaFolder[]
  mediaFiles       MediaFile[]
  aiUsageLogs      AiUsageLog[]
  webhookRules     WebhookRule[]
  users            UserBusiness[]
  storyTemplates      StoryTemplate[]
  characterRelations  CharacterBusiness[]
  scenarios           Scenario[]
  promptEntries       PromptEntry[]
  promptTemplates     PromptTemplate[]
  sessions            GenerationSession[]
  socialPostMetrics    SocialPostMetricSnapshot[]
  socialAccountMetrics SocialAccountMetricSnapshot[]
  siteTraffic          SiteTrafficSnapshot[]
  analyticsReports     AnalyticsReport[]
  rubrics              Rubric[]
  occasions            Occasion[]
  competitorAccounts   CompetitorAccount[]

  @@map("businesses")
}

/// Контент-рубрика бизнеса (strategy-as-data, Эпик B Phase 3) — вместо хардкода NAWODE_RUBRICS
model Rubric {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  name        String                          // "Выборг с воды"
  description String?                          // опц. описание/гайд для AI
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("rubrics")
}

/// Сезонный повод/праздник бизнеса (strategy-as-data, Эпик B Phase 3) — вместо хардкода NAWODE_EVENTS
model Occasion {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  monthDay   String   @map("month_day")        // "MM-DD" (год-независимо)
  topic      String                            // тема поста на этот повод
  rubric     String                            // название рубрики (строкой, как в коде)
  postType   String?  @map("post_type")        // опц. предпочтительный формат
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("occasions")
}

model StoryTemplate {
  id           String   @id @default(cuid())
  businessId   String?  @map("business_id")              // null = глобальный пресет
  isSystem     Boolean  @default(false) @map("is_system") // системный дизайн-пресет
  name         String                                    // "SUP рассвет", "Акция"
  emoji        String   @default("")                     // "🌅", "🔥"
  overlayText  String   @default("") @map("overlay_text") // текст на фото (пусто = пресет только стиля)
  textPosition String   @default("bottom") @map("text_position") // top/center/bottom
  textColor    String   @default("#ffffff") @map("text_color")
  fontSize     String   @default("M") @map("font_size")  // S/M/L
  bgStyle      String   @default("dark") @map("bg_style") // dark/light/none
  textAlign    String   @default("center") @map("text_align") // left/center/right
  bgRadius     String   @default("round") @map("bg_radius")    // round/square
  linkType     String   @default("") @map("link_type")   // book/order/learn_more/""
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("story_templates")
}

/// Профиль бренда (контекст для AI-промптов)
model BrandProfile {
  id              String   @id @default(cuid())
  businessId      String   @unique @map("business_id")
  tone            String   @default("") // "дружелюбный, профессиональный"
  targetAudience  String   @default("") @map("target_audience")
  brandVoice      String   @default("") @map("brand_voice") // описание стиля
  hashtags        String[] @default([]) // постоянные хештеги бренда
  keyTopics       String[] @default([]) @map("key_topics")
  doNotMention    String[] @default([]) @map("do_not_mention")
  examplePosts    Json?    @map("example_posts") // примеры хороших постов
  postsPerWeek    Int      @default(3) @map("posts_per_week")
  links           Json?    // [{label: "Сайт", url: "https://..."}, {label: "Бронирование", url: "..."}]
  // strategy-as-data (Эпик B Phase 3): контент-стратегия per-business вместо хардкода в коде
  contentStrategy String?  @map("content_strategy") // блок стратегии для system-промптов агента/плана
  seasonHints     Json?    @map("season_hints")     // [{months:number[], hint:string}] — сезонные ориентиры (months:[] = default)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  @@map("brand_profiles")
}

/// Привязка к соцсети (VK-группа, TG-канал, IG-аккаунт)
model PlatformAccount {
  id           String      @id @default(cuid())
  businessId   String      @map("business_id")
  platform     Platform
  accountType  AccountType @default(GROUP) @map("account_type")
  accountName  String      @map("account_name") // "SUP клуб НаWоде" или "@nawode"
  accountId    String      @map("account_id") // VK group_id, TG chat_id, IG user_id
  accessToken  String      @map("access_token")
  tokenExpires DateTime?   @map("token_expires")
  isActive     Boolean     @default(true) @map("is_active")
  config       Json?       // доп. настройки (proxyUrl для IG и т.д.)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  business     Business      @relation(fields: [businessId], references: [id])
  postVersions PostVersion[]

  @@unique([businessId, platform, accountId])
  @@map("platform_accounts")
}

/// Контент-план на период
model ContentPlan {
  id           String            @id @default(cuid())
  businessId   String            @map("business_id")
  title        String            // "Контент-план Июнь 2026"
  startDate    DateTime          @map("start_date")
  endDate      DateTime          @map("end_date")
  status       ContentPlanStatus @default(DRAFT)
  generatedBy  String            @default("manual") @map("generated_by") // "ai" | "manual"
  aiPromptUsed String?           @map("ai_prompt_used")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  business Business          @relation(fields: [businessId], references: [id])
  items    ContentPlanItem[]

  @@index([businessId])
  @@map("content_plans")
}

/// Ячейка контент-плана
model ContentPlanItem {
  id            String   @id @default(cuid())
  contentPlanId String   @map("content_plan_id")
  date          DateTime
  dayOfWeek     String   @map("day_of_week") // "Понедельник"
  topic         String
  postType      PostType @default(TEXT) @map("post_type")
  description   String?
  status        String   @default("PLANNED") // PLANNED, IN_PROGRESS, PUBLISHED, SKIPPED
  postId        String?  @map("post_id") // связь с реальным постом
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contentPlan ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  post        Post?       @relation(fields: [postId], references: [id])

  @@map("content_plan_items")
}

/// Основной контент (мастер-текст)
model Post {
  id                String     @id @default(cuid())
  businessId        String     @map("business_id")
  title             String?    // заголовок (опционально)
  body              String     // мастер-текст
  postType          PostType   @default(TEXT) @map("post_type")
  hashtags          String[]   @default([])
  status            PostStatus @default(DRAFT)
  scheduledAt       DateTime?  @map("scheduled_at")
  createdBy         String     @default("manual") @map("created_by") // "ai" | "manual"
  aiModel           String?    @map("ai_model")
  aiPromptUsed      String?    @map("ai_prompt_used")
  aiPromptHistory   Json?      @map("ai_prompt_history")
  contentPlanItemId String?    @map("content_plan_item_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  business         Business          @relation(fields: [businessId], references: [id])
  versions         PostVersion[]
  mediaFiles       MediaFile[]
  contentPlanItems ContentPlanItem[]
  metricSnapshots  SocialPostMetricSnapshot[]
  siteTraffic      SiteTrafficSnapshot[]

  @@index([businessId])
  @@index([status])
  @@map("posts")
}

/// Адаптация поста под конкретную платформу
model PostVersion {
  id                String     @id @default(cuid())
  postId            String     @map("post_id")
  platformAccountId String     @map("platform_account_id")
  body              String     // адаптированный текст
  hashtags          String[]   @default([])
  status            PostStatus @default(DRAFT)
  scheduledAt       DateTime?  @map("scheduled_at")
  publishedAt       DateTime?  @map("published_at")
  externalPostId    String?    @map("external_post_id") // ID в соцсети
  externalUrl       String?    @map("external_url") // ссылка на пост
  publishOptions    Json?      @map("publish_options") // опции публикации для отложки сторис: { skipOverlay, linkText, linkUrl, photoPosition, audioUrl?, musicSessionId? }
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  post            Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  platformAccount PlatformAccount  @relation(fields: [platformAccountId], references: [id])
  publishLogs     PublishLog[]
  metricSnapshots SocialPostMetricSnapshot[]

  @@unique([postId, platformAccountId])
  @@index([status])
  @@index([status, scheduledAt])
  @@map("post_versions")
}

/// Лог публикации (каждая попытка)
model PublishLog {
  id            String        @id @default(cuid())
  postVersionId String        @map("post_version_id")
  status        PublishStatus
  response      Json?         // ответ API соцсети
  errorMessage  String?       @map("error_message")
  attemptedAt   DateTime      @default(now()) @map("attempted_at")

  postVersion PostVersion @relation(fields: [postVersionId], references: [id], onDelete: Cascade)

  @@map("publish_logs")
}

/// Папки медиатеки
model MediaFolder {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  name       String
  parentId   String?  @map("parent_id")
  createdAt  DateTime @default(now()) @map("created_at")

  business Business     @relation(fields: [businessId], references: [id])
  parent   MediaFolder? @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MediaFolder[] @relation("FolderTree")
  files    MediaFile[]

  @@index([businessId])
  @@index([parentId])
  @@map("media_folders")
}

/// Медиафайлы (изображения, видео)
model MediaFile {
  id          String   @id @default(cuid())
  postId      String?  @map("post_id")
  businessId  String   @map("business_id")
  folderId    String?  @map("folder_id")
  filename    String
  url         String
  thumbUrl    String?  @map("thumb_url")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  altText     String?  @map("alt_text")
  tags        String[] @default([])
  sortOrder   Int      @default(0) @map("sort_order")
  durationSec Int?     @map("duration_sec") // длительность видео/аудио в секундах
  aiModel     String?  @map("ai_model")     // модель генерации (nano-banana-2, bytedance/seedance-2, etc.)
  aiCostUsd   Float?   @map("ai_cost_usd")  // стоимость генерации в USD
  createdAt   DateTime @default(now()) @map("created_at")

  post         Post?        @relation(fields: [postId], references: [id])
  business     Business     @relation(fields: [businessId], references: [id])
  folder       MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  characterRef    Character[]           @relation("CharacterReference")
  characterImages CharacterImage[]     @relation("CharacterImageMedia")
  sessions        GenerationSession[]  @relation("SessionMediaFile")
  personaSamples  MusicPersona[]       @relation("PersonaSample")

  @@index([businessId])
  @@index([postId])
  @@index([folderId])
  @@map("media_files")
}

/// Трекинг расходов на AI
model AiUsageLog {
  id           String   @id @default(cuid())
  businessId   String?  @map("business_id")
  userId       String?  @map("user_id")
  action       String   // "generate_plan", "generate_post", "adapt_platform", etc.
  model        String   // "anthropic/claude-3.5-haiku"
  tokensIn     Int      @map("tokens_in")
  tokensOut    Int      @map("tokens_out")
  cachedTokens Int      @default(0) @map("cached_tokens")
  costUsd        Float    @default(0) @map("cost_usd")
  markupPercent  Float?   @map("markup_percent")   // наценка % на момент вызова (snapshot)
  chargedRub     Float?   @map("charged_rub")      // списано с пользователя в рублях (с наценкой)
  status         String   @default("success") // "success" | "error"
  errorMessage String?  @map("error_message")
  prompt       String?  // отправленный промпт (truncated до 2000 символов)
  durationMs   Int?     @map("duration_ms") // время выполнения в мс
  createdAt    DateTime @default(now()) @map("created_at")

  business Business? @relation(fields: [businessId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

/// Правила webhook-интеграции с ERP
model WebhookRule {
  id             String   @id @default(cuid())
  businessId     String   @map("business_id")
  erpEvent       String   @map("erp_event") // "tour_created", "event_created"
  action         String   // "generate_draft", "generate_and_approve", "notify_only"
  templatePrompt String?  @map("template_prompt")
  platforms      String[] @default([]) // ["VK", "TELEGRAM"]
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  @@map("webhook_rules")
}

/// Личные заметки/идеи пользователя (per-user блокнот)
model Idea {
  id        String   @id @default(cuid())
  title     String   @default("")
  body      String   @default("")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ideas")
}

/// Глобальные настройки приложения (key-value)
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

/// Библиотека промптов (сохранённые промпты с результатами и рейтингом)
model PromptEntry {
  id        String   @id @default(cuid())
  businessId String  @map("business_id")
  type      String   @default("video") // "video" | "image" | "text"
  prompt    String
  resultUrl String?  @map("result_url") // URL сгенерированного медиа
  rating    Int?     // 1-5 или null
  tags      String[] @default([])
  metadata  Json?    // { duration, model, cost, aspectRatio, audio }
  createdAt DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([type])
  @@map("prompt_entries")
}

/// Шаблоны промптов (редактируемые, per-business или глобальные)
model PromptTemplate {
  id        String   @id @default(cuid())
  businessId String? @map("business_id") // null = глобальный
  type      String   @default("video")   // "video" | "image" | "text"
  name      String
  emoji     String   @default("")
  prompt    String
  tags      String[] @default([])
  isSystem  Boolean  @default(false) @map("is_system")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([type])
  @@map("prompt_templates")
}

/// AI-персонаж (глобальный, привязывается к бизнесам через CharacterBusiness)
model Character {
  id               String   @id @default(cuid())
  name             String                          // "Юрий", "SUP-маскот"
  description      String   @default("")           // описание для AI-промпта
  type             String   @default("person")     // "person" | "mascot" | "avatar"
  style            String   @default("")           // "cartoon", "realistic", "anime"
  referenceMediaId String?  @map("reference_media_id")
  additionalAngles Json?    @map("additional_angles")   // [{url, thumbUrl, filename}] — до 3 доп. ракурсов
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  referenceMedia MediaFile?          @relation("CharacterReference", fields: [referenceMediaId], references: [id])
  businesses     CharacterBusiness[]
  images         CharacterImage[]

  @@map("characters")
}

/// Привязка персонажа к бизнесу (M:N)
model CharacterBusiness {
  id          String   @id @default(cuid())
  characterId String   @map("character_id")
  businessId  String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([characterId, businessId])
  @@index([businessId])
  @@index([characterId])
  @@map("character_businesses")
}

/// Фото персонажа (галерея, one-to-many к Character)
model CharacterImage {
  id           String   @id @default(cuid())
  characterId  String   @map("character_id")
  mediaFileId  String   @map("media_file_id")
  description  String   @default("")              // AI или ручное описание фото
  isMain       Boolean  @default(false) @map("is_main")  // главный аватар
  sortOrder    Int      @default(0)     @map("sort_order")
  source       String   @default("upload")        // "upload" | "character_sheet" | "generated"
  createdAt    DateTime @default(now()) @map("created_at")

  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  mediaFile    MediaFile @relation("CharacterImageMedia", fields: [mediaFileId], references: [id])

  @@unique([characterId, mediaFileId])
  @@index([characterId])
  @@map("character_images")
}

/// Сценарий для видео/контента (структурированный набор сцен)
model Scenario {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  title        String
  description  String   @default("")
  scenes       Json     @default("[]") // [{sceneNumber, description, voiceover, durationSec, imagePrompt}]
  status       String   @default("DRAFT") // DRAFT, READY, IN_PRODUCTION, COMPLETED
  generatedBy  String   @default("manual") @map("generated_by") // "ai" | "manual"
  aiPromptUsed String?  @map("ai_prompt_used")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("scenarios")
}

/// Сессия генерации видео/музыки (полный контекст: промпт + референсы + настройки + результат)
model GenerationSession {
  id               String   @id @default(cuid())
  businessId       String   @map("business_id")
  userId           String   @map("user_id")

  // Тип сессии (video | music | photo)
  type             String   @default("video")

  // Название (авто из промпта или ручное)
  title            String   @default("")

  // Промпт
  prompt           String   @default("")
  promptHistory    Json?    @map("prompt_history")    // [{version, prompt, createdAt}]
  chatHistory      Json?    @map("chat_history")      // [{role, content, prompts?, suggestions?, createdAt}]

  // Настройки видео
  duration         Int      @default(4)
  aspectRatio      String   @default("9:16") @map("aspect_ratio")
  resolution       String   @default("480p")
  generateAudio    Boolean  @default(false) @map("generate_audio")
  inputMode        String   @default("references") @map("input_mode") // text | frames | references

  // Референсы видео (JSON)
  referenceImages  Json?    @map("reference_images")  // [{url, thumbUrl, filename, altText}]
  firstFrameUrl    String?  @map("first_frame_url")
  lastFrameUrl     String?  @map("last_frame_url")

  // === Настройки музыки (null для video сессий) ===
  customMode          Boolean? @map("custom_mode")          // false = Simple, true = Custom (lyrics+style)
  instrumental        Boolean? @map("instrumental")          // true = без вокала
  lyrics              String?                                // текст песни с [Verse]/[Chorus] маркерами
  musicStyle          String?  @map("music_style")           // "indie rock, melancholic, 120 bpm" (до 1000 символов)
  musicTitle          String?  @map("music_title")           // название трека (до 80 символов)
  negativeTags        String?  @map("negative_tags")         // "metal, screaming" — стили для исключения
  vocalGender         String?  @map("vocal_gender")          // "m" | "f"
  styleWeight         Float?   @map("style_weight")          // 0-1, вес стиля в генерации
  weirdnessConstraint Float?   @map("weirdness_constraint")  // 0-1, креативность
  audioWeight         Float?   @map("audio_weight")          // 0-1, влияние аудио на результат
  personaId           String?  @map("persona_id")            // FK to MusicPersona (voice clone)
  coverImageUrl       String?  @map("cover_image_url")       // обложка от Suno
  audioUrl            String?  @map("audio_url")             // скачанный audio файл (local)
  streamAudioUrl      String?  @map("stream_audio_url")      // streaming URL от Suno
  sunoModel           String?  @map("suno_model")            // "suno/v4" | "suno/v4.5" | "suno/v5.5"

  // === Настройки фото (null для video/music сессий) ===
  photoModel          String?  @map("photo_model")            // "nano-banana-2" | "nano-banana-pro"
  photoResolution     String?  @map("photo_resolution")       // "1K" | "2K" | "4K"
  batchSize           Int?     @map("batch_size")              // 1 | 2 | 4
  photoAspectRatio    String?  @map("photo_aspect_ratio")     // "1:1" | "2:3" | "3:2" | "9:16" | etc.
  batchTaskIds        Json?    @map("batch_task_ids")          // ["taskId1", "taskId2", ...] for parallel tasks

  // Генерация (async task)
  status           String   @default("draft")         // draft | generating | completed | failed
  kieTaskId        String?  @map("kie_task_id")       // taskId от KIE.ai для async polling
  kieTaskCreatedAt DateTime? @map("kie_task_created_at")

  // Completed KIE IDs (preserved after generation for Generate Persona)
  completedTaskId  String?  @map("completed_task_id")  // kieTaskId сохранённый после завершения
  kieAudioId       String?  @map("kie_audio_id")       // audioId из KIE response (для Generate Persona)

  // Результат
  mediaFileId      String?  @map("media_file_id")
  resultUrl        String?  @map("result_url")
  errorMessage     String?  @map("error_message")

  // Результаты генераций (несколько попыток внутри сессии)
  results          Json?    @map("results")           // [{resultUrl, prompt, costUsd, createdAt, mediaFileId}]

  // Стоимость (суммарная)
  model            String   @default("bytedance/seedance-2")
  costUsd          Float?   @map("cost_usd")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  business  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  mediaFile MediaFile?    @relation("SessionMediaFile", fields: [mediaFileId], references: [id])
  persona   MusicPersona? @relation(fields: [personaId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("generation_sessions")
}

/// Голосовая персона для музыки (voice cloning через Suno V5.5)
model MusicPersona {
  id            String   @id @default(cuid())
  name          String                              // "Женский инди-вокал"
  description   String   @default("")               // "Мягкий женский голос, инди-фолк стиль"
  gender        String?                             // "m" | "f" | "neutral"
  sampleMediaId String?  @map("sample_media_id")   // FK to MediaFile (voice sample audio)
  sunoPersonaId String?  @map("suno_persona_id")   // ID персоны из Suno V5.5 Generate Persona API
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sampleMedia MediaFile?          @relation("PersonaSample", fields: [sampleMediaId], references: [id])
  sessions    GenerationSession[]

  @@map("music_personas")
}

/// История пополнений и списаний баланса пользователя
model BalanceTransaction {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  amountKopecks  Int      @map("amount_kopecks") // положительный = пополнение, отрицательный = списание
  type           String   // "topup" | "charge" | "refund" | "adjustment"
  description    String?  // "Пополнение от 16.04" или "Генерация поста"
  aiUsageLogId   String?  @map("ai_usage_log_id") // связь с конкретным AI-вызовом (для charge)
  adminId        String?  @map("admin_id") // кто пополнил (для topup)
  balanceAfter   Int      @map("balance_after") // баланс ПОСЛЕ транзакции (snapshot)
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("balance_transactions")
}

// ============================================================
// GOOGLE PHOTOS SYNC
// ============================================================

/// Каталог файлов из Google Photos (синхронизированных через rclone)
/// Фото остаются в приватной директории /data/google-photos/
/// В CF MediaLibrary попадают ТОЛЬКО после одобрения пользователем
model PhotoCatalog {
  id          String    @id @default(cuid())
  filePath    String    @unique @map("file_path")       // /app/google-photos/album/IMG_123.jpg
  fileHash    String?   @map("file_hash")                // md5 для дедупликации
  fileSize    Int       @map("file_size")                 // bytes
  mimeType    String    @map("mime_type")                 // image/jpeg, video/mp4
  fileDate    DateTime? @map("file_date")                 // из EXIF или mtime
  albumName   String?   @map("album_name")                // из структуры папок rclone
  thumbPath   String?   @map("thumb_path")                // .thumbs/abc.webp

  // AI-поля (заполняются по запросу, НЕ для всех файлов)
  aiDescription String?  @map("ai_description")
  aiBusiness    String?  @map("ai_business")              // KB/НаWоде/Inpulse/личное
  aiConfidence  Float?   @map("ai_confidence")            // 0.0-1.0
  aiTags        String[] @default([]) @map("ai_tags")
  aiAnalyzedAt  DateTime? @map("ai_analyzed_at")

  // Статусы
  status        String   @default("indexed")              // indexed|analyzed|posted|skipped
  mediaFileId   String?  @map("media_file_id")            // FK -> MediaFile (после одобрения)
  postedAt      DateTime? @map("posted_at")

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([aiBusiness])
  @@index([fileDate])
  @@map("photo_catalog")
}

/// Задача авто-постинга (AI предлагает фото -> Telegram одобрение -> публикация)
model AutoPostTask {
  id            String    @id @default(cuid())
  businessId    String    @map("business_id")
  catalogId     String?   @map("catalog_id")              // FK -> PhotoCatalog (null для digest-задач)
  source        String    @default("photo")               // "photo" (Google Photos) | "digest" (утренний агент)
  postId        String?   @map("post_id")                  // FK -> Post (после одобрения)
  mediaFileId   String?   @map("media_file_id")            // FK -> MediaFile (после одобрения)
  status        String    @default("pending")              // pending|proposed|approved|rejected|editing|published
  postType      String?   @map("post_type")               // предлагаемый формат: STORIES|TEXT|PHOTO|REELS
  title         String?                                     // предлагаемый заголовок
  proposedText  String    @map("proposed_text")            // AI-сгенерированный мастер-текст
  proposedTags  String[]  @default([]) @map("proposed_tags")
  adaptations   Json?     @map("adaptations")              // per-platform версии [{platform,text,hashtags}] (Ф1.5)
  visualIdea    String?   @map("visual_idea")             // идея визуала (фото/видео)
  aiReasoning   String?   @map("ai_reasoning")             // почему именно это (погода/бронь/рубрика)
  platforms     String[]  @default([])                      // ["VK", "TELEGRAM"]
  suggestedFor  DateTime? @map("suggested_for")           // предлагаемая дата/время публикации
  tgMessageId   String?   @map("tg_message_id")            // ID сообщения для edit
  proposedAt    DateTime? @map("proposed_at")
  decidedAt     DateTime? @map("decided_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([businessId])
  @@index([source])
  @@map("auto_post_tasks")
}

// ============================================================
// SMM ANALYTICS (Эпик B — сбор статистики + петля обратной связи)
// ============================================================

/// Снимок метрик опубликованного поста/сторис/рилса (append-only, по каждому pull).
/// Площадки удаляют историю (IG-сторис ~14д), поэтому НЕ UPDATE, а новый snapshot —
/// получаем time-series. `raw` ловит недокументированные ключи площадки.
/// Связь с CF Post — best-effort (post_id/post_version_id nullable): снимок ценен и без неё.
model SocialPostMetricSnapshot {
  id              String   @id @default(cuid())
  businessId      String   @map("business_id")
  postId          String?  @map("post_id")               // best-effort связь с CF Post
  postVersionId   String?  @map("post_version_id")        // и с конкретной версией-публикацией
  platform        Platform
  source          String                                  // "VK" | "POSTMYPOST" | "TELEGRAM"
  publicationType String   @default("POST") @map("publication_type") // POST|STORY|REELS
  externalId      String   @map("external_id")            // VK post_id / IG media id
  externalUrl     String?  @map("external_url")

  // Нормализованные метрики (что доступно у площадки — остальное null + raw)
  impressions     Int?
  reach           Int?
  views           Int?
  likes           Int?
  comments        Int?
  shares          Int?
  saves           Int?
  storyExits      Int?     @map("story_exits")
  storyReplies    Int?     @map("story_replies")
  engagementRate  Float?   @map("engagement_rate")        // сами считаем или берём у площадки

  capturedAt      DateTime @default(now()) @map("captured_at")
  raw             Json?                                    // вербатим ответ площадки

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  post        Post?        @relation(fields: [postId], references: [id])
  postVersion PostVersion? @relation(fields: [postVersionId], references: [id])

  @@index([businessId, platform])
  @@index([postId])
  @@index([externalId])
  @@index([capturedAt])
  @@map("social_post_metric_snapshots")
}

/// Снимок метрик аккаунта/профиля (подписчики, охват профиля, демография) — time-series.
/// Upsert по (бизнес, аккаунт, метрика, дата) — данные стабильны исторически.
model SocialAccountMetricSnapshot {
  id                String   @id @default(cuid())
  businessId        String   @map("business_id")
  platform          Platform
  source            String                                  // VK|POSTMYPOST|TELEGRAM
  accountExternalId String   @map("account_external_id")
  metricCode        String   @map("metric_code")            // followers|reach|profile_views|...
  value             Float
  metricDate        DateTime @map("metric_date") @db.Date
  capturedAt        DateTime @default(now()) @map("captured_at")
  raw               Json?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, accountExternalId, metricCode, metricDate])
  @@index([businessId, platform])
  @@map("social_account_metric_snapshots")
}

/// Снимок веб-трафика из Яндекс.Метрики по UTM-меткам (мост соцтрафик → конверсии).
/// utm_content = postId — главный ключ джойна к CF Post и его метрикам.
/// Upsert по (бизнес, счётчик, utm_content, utm_source, дата) — Метрика исторична.
model SiteTrafficSnapshot {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  counterId    String   @map("counter_id")                 // Metrika counter (напр. 92916147)
  source       String   @default("METRIKA")
  utmSource    String?  @map("utm_source")                 // vk|telegram|instagram
  utmMedium    String?  @map("utm_medium")
  utmCampaign  String?  @map("utm_campaign")               // cf_YYYY_MM
  utmContent   String?  @map("utm_content")                // = postId (JOIN key)
  postId       String?  @map("post_id")                    // резолв из utm_content
  metricDate   DateTime @map("metric_date") @db.Date
  visits       Int      @default(0)
  users        Int?
  bounceRate   Float?   @map("bounce_rate")
  goalReaches  Json?    @map("goal_reaches")               // {goalId: reaches} — конверсии (брони)
  capturedAt   DateTime @default(now()) @map("captured_at")
  raw          Json?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id])

  @@unique([businessId, counterId, utmContent, utmSource, metricDate])
  @@index([businessId])
  @@index([postId])
  @@index([metricDate])
  @@map("site_traffic_snapshots")
}

/// Недельный отчёт агента-аналитика (петля улучшения SMM, Phase 5).
/// Sonnet анализирует контент + метрики + конверсии(UTM) → выводы + рекомендации.
/// Human-in-the-loop: proposed → approved/dismissed (как daily-digest).
model AnalyticsReport {
  id              String    @id @default(cuid())
  businessId      String    @map("business_id")
  periodStart     DateTime  @map("period_start")
  periodEnd       DateTime  @map("period_end")
  status          String    @default("proposed")            // proposed|approved|dismissed
  summary         String                                     // краткий вывод (что зашло/не зашло)
  findings        Json?                                      // [{type, title, detail, metric}]
  recommendations Json?     @map("recommendations")          // [{area, action, reason}]
  metricsJson     Json?     @map("metrics_json")             // агрегаты на момент отчёта (для дашборда)
  model           String    @default("anthropic/claude-sonnet-4")
  generatedBy     String    @default("agent") @map("generated_by") // agent|manual
  createdAt       DateTime  @default(now()) @map("created_at")
  decidedAt       DateTime? @map("decided_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@map("analytics_reports")
}

/// Аккаунт конкурента/смежника для мониторинга (модуль «Конкуренты», MVP — VK).
/// Читаем публичную стену через wall.get тем же VK-токеном (scope не нужен).
model CompetitorAccount {
  id            String    @id @default(cuid())
  businessId    String    @map("business_id")
  platform      Platform  @default(VK)
  handle        String                                    // VK: domain ("supway") или "-12345678" (owner_id)
  displayName   String    @map("display_name")            // "SUP Way SPB"
  category      String    @default("competitor")          // competitor | adjacent | inspiration | self
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?
  lastFetchedAt DateTime? @map("last_fetched_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  posts    CompetitorPost[]

  @@unique([businessId, platform, handle])
  @@index([businessId])
  @@map("competitor_accounts")
}

/// Снимок поста конкурента с метриками + флаг «залетел» (виральность по ER).
model CompetitorPost {
  id             String   @id @default(cuid())
  accountId      String   @map("account_id")
  externalId     String   @map("external_id")            // VK post id
  externalUrl    String   @map("external_url")
  publishedAt    DateTime @map("published_at")
  text           String   @default("")
  mediaType      String?  @map("media_type")             // photo | video | link | null
  likes          Int      @default(0)
  reposts        Int      @default(0)
  views          Int      @default(0)
  comments       Int      @default(0)
  engagementRate Float?   @map("engagement_rate")         // (likes+reposts+comments)/views*100
  isViral        Boolean  @default(false) @map("is_viral")
  capturedAt     DateTime @default(now()) @map("captured_at")
  raw            Json?

  account CompetitorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, externalId])
  @@index([accountId, publishedAt])
  @@index([isViral])
  @@map("competitor_posts")
}
