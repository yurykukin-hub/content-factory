# Локальная dev-БД (docker-compose.dev.yml). Прод использует отдельный пароль из .env.prod.
DATABASE_URL="postgresql://contentfactory:cf_dev_password@localhost:5441/contentfactory_dev"
# JWT_SECRET: ≥32 символов. В production сервер падает, если секрет короче, равен этому
# плейсхолдеру или похож на dev-ключ (содержит -dev-/dev-key).
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
PORT=3800
OPENROUTER_API_KEY="sk-or-..."
KIE_API_KEY="kie-..."

# Пароли сид-юзеров (backend/src/seed.ts) — только из env, не хардкод. Минимум 8 символов.
# db:fresh / db:seed без них упадут. admin ← SEED_ADMIN_PASSWORD; sveta/anton ← SEED_DEFAULT_PASSWORD.
SEED_ADMIN_PASSWORD="change-me-min-8-chars"
SEED_DEFAULT_PASSWORD="change-me-min-8-chars"

# НаWоде ERP (read-only) for the morning AI content agent (Epic C). Optional — if unset, digest skips ERP data.
NAWODE_DATABASE_URL=postgresql://user:pass@host:5436/nawode

# Postmypost — публикация IG и VK-стены/фото (обход застрявшего scope `photos` в VK).
# IG-аккаунт хранит токен в PlatformAccount.accessToken; для VK-через-Postmypost
# токен берётся ОТСЮДА (project-level credential, не из config — config утекает во фронт).
# project_id — fallback, если у аккаунта нет config.postmypostProjectId.
POSTMYPOST_API_TOKEN=""
POSTMYPOST_PROJECT_ID=""
