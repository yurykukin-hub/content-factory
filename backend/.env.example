DATABASE_URL="postgresql://contentfactory:secret@localhost:5441/contentfactory"
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
PORT=3800
OPENROUTER_API_KEY="sk-or-..."
KIE_API_KEY="kie-..."

# НаWоде ERP (read-only) for the morning AI content agent (Epic C). Optional — if unset, digest skips ERP data.
NAWODE_DATABASE_URL=postgresql://user:pass@host:5436/nawode

# Postmypost — публикация IG и VK-стены/фото (обход застрявшего scope `photos` в VK).
# IG-аккаунт хранит токен в PlatformAccount.accessToken; для VK-через-Postmypost
# токен берётся ОТСЮДА (project-level credential, не из config — config утекает во фронт).
# project_id — fallback, если у аккаунта нет config.postmypostProjectId.
POSTMYPOST_API_TOKEN=""
POSTMYPOST_PROJECT_ID=""
