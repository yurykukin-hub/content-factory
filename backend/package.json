{
  "name": "content-factory-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:studio": "bunx prisma studio",
    "db:seed": "bun src/seed.ts",
    "db:reset": "bunx prisma migrate reset --force",
    "db:fresh": "bunx prisma migrate reset --force && bun src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@resvg/resvg-js": "^2.6.2",
    "hono": "^4.7.5",
    "jose": "^5.10.0",
    "nanoid": "^5.1.7",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.4.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
